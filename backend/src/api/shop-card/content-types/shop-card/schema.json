{
  "kind": "collectionType",
  "collectionName": "shop_cards",
  "info": {
    "singularName": "shop-card",
    "pluralName": "shop-cards",
    "displayName": "Shop Card"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "json"
    },
    "variants": {
      "type": "json"
    },
    "requiredDifficulties": {
      "type": "json"
    },
    "splineUrl": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": ["available", "not_available"],
      "default": "available",
      "required": true
    }
  }
}
