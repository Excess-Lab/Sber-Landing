{
  "kind": "collectionType",
  "collectionName": "daily_checkins",
  "info": {
    "singularName": "daily-checkin",
    "pluralName": "daily-checkins",
    "displayName": "Daily Checkin",
    "description": "Daily participation check-ins with approval"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "day": {
      "type": "date",
      "required": true
    },
    "dayKey": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "rejected"],
      "default": "pending",
      "required": true
    },
    "points": {
      "type": "integer",
      "default": 10,
      "min": 0,
      "required": true
    },
    "approvedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "pointsApplied": {
      "type": "boolean",
      "default": false,
      "required": true
    }
  }
}
