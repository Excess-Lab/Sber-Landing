{
  "kind": "collectionType",
  "collectionName": "user_challenges",
  "info": {
    "singularName": "user-challenge",
    "pluralName": "user-challenges",
    "displayName": "User Challenge",
    "description": "User submissions and approval status for challenges"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "challenge": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::challenge.challenge",
      "required": true
    },
    "team": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "rejected"],
      "default": "pending",
      "required": true
    },
    "approvedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "submittedAt": {
      "type": "datetime"
    },
    "submissionText": {
      "type": "text"
    },
    "submissionLinks": {
      "type": "text"
    },
    "completedAt": {
      "type": "datetime"
    },
    "xpApplied": {
      "type": "boolean",
      "default": false,
      "required": true
    }
  }
}
